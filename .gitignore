# macOS 元数据文件
.DS_Store
._*

# 依赖目录（不要上传到 Git）
node_modules/

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 环境变量（包含 API Key 等敏感信息）
.env
.env.local
.env.*.local

# 临时文件
*.tmp
*.swp
*.swo
*~

# 编辑器/IDE 配置
.qwen/
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# 构建输出
dist/
build/
*.tgz

# 系统文件
Thumbs.db
.DS_Store
